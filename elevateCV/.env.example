# ============================================================
# ElevateCV — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# Only needed for production deployments.
# In development, Vite automatically proxies /api → localhost:3002
# ============================================================

# Backend API URL — only set this for production/staging deployments
# In development (npm run dev), leave this blank — the Vite proxy handles it
VITE_API_URL=
